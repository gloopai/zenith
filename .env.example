# 站点对外 URL（用于 sitemap、og:url；生产环境建议设置）
# 例如：https://plunget.com/
NUXT_PUBLIC_SITE_URL=

# --- 可选：从收件箱自动生成中文资讯稿（OpenAI 兼容 Chat Completions）---
# 通义千问（阿里云百炼 DashScope，推荐与本站中文一致）：
# DASHSCOPE_API_KEY=
# NEWS_GEN_MODEL=qwen-plus
# 国内默认 base 可不设；国际区可设：
# DASHSCOPE_COMPAT_BASE=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# 或显式：NEWS_GEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#
# OpenAI / OpenRouter 等（未配置 DASHSCOPE 时使用）：
# NEWS_GEN_API_KEY=
# OPENAI_API_KEY=
# NEWS_GEN_MODEL=gpt-4o-mini
# NEWS_GEN_BASE_URL=https://api.openai.com/v1
# 同时有 DashScope 与 OpenAI 时默认走千问；要强开 OpenAI：NEWS_GEN_PROVIDER=openai
